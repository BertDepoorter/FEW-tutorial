Cell[BoxData[{
 RowBox[{
  RowBox[{"<<", "Teukolsky`"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Pure", " ", "mode", " ", "amplitudes"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GetAmp", "[", 
   RowBox[{"rp_", ",", "a_", ",", "l_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"l", ">=", 
        RowBox[{"Abs", "[", "m", "]"}]}], " ", "&&", " ", 
       RowBox[{"l", ">=", "2"}], "&&", 
       RowBox[{"m", "!=", "0"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"orbit", "=", 
        RowBox[{"KerrGeoOrbit", "[", 
         RowBox[{"a", ",", "rp", ",", "0", ",", "1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Psi]4", "=", 
        RowBox[{"TeukolskyPointParticleMode", "[", 
         RowBox[{
          RowBox[{"-", "2"}], ",", "l", ",", "m", ",", "orbit"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"omeg", "=", 
        RowBox[{"\[Psi]4", "[", "\"\<\[Omega]\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "/", 
         SuperscriptBox["omeg", "2"]}], "*", 
        RowBox[{
         RowBox[{"\[Psi]4", "[", "\"\<Amplitudes\>\"", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
      "0"}], "]"}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
